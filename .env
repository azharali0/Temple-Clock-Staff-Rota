# CareShift API — Environment Variables
# Copy this file to .env and fill in your values.

# ── Core ──────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
MONGO_URI=mongodb://CareShift123:CareShift123@ac-zqbnb8z-shard-00-00.ooybw1n.mongodb.net:27017,ac-zqbnb8z-shard-00-01.ooybw1n.mongodb.net:27017,ac-zqbnb8z-shard-00-02.ooybw1n.mongodb.net:27017/careshift?ssl=true&replicaSet=atlas-5wkek6-shard-0&authSource=admin&appName=ClusterCare
JWT_SECRET=careshift_super_secret_key_2025

# ── Frontend URL (used for QR code links) ─────────────────────────
FRONTEND_URL=http://localhost:8080

# ── Twilio SMS (Optional — leave empty to disable) ────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# ── Cloudinary Image Upload (Optional — leave empty to disable) ───
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Redis Caching (Optional — leave empty to disable) ─────────────
REDIS_URL=
